   "source": [
    "ch_bol = 1800\n",
    "ch_lig = 1800\n",
    "kh_bol = 1 #kh/s\n",
    "kh_lig = 2 #kh/s\n",
    "sz_bol = 16 # bit\n",
    "sz_lig = 16 # bit\n",
    "\n",
    "Tp = ch_bol*kh_bol*sz_bol+ch_lig*kh_lig*sz_lig\n",
    "print(\"thoughtput: {} kb/s\".format(Tp))\n",
    "print(\"thoughtput: {} kB/s {} MB/s\".format(Tp/8, Tp/8/1000), )"
   ]
